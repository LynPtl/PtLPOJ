{
  "name": "ptlpoj-client",
  "displayName": "PtLPOJ Local Judge",
  "description": "Inner Team Python Online Judge Client",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ptlpoj.login",
        "title": "PtLPOJ: Login via OTP"
      },
      {
        "command": "ptlpoj.refreshProblems",
        "title": "PtLPOJ: Refresh Problems"
      },
      {
        "command": "ptlpoj.openProblem",
        "title": "PtLPOJ: Open Problem"
      },
      {
        "command": "ptlpoj.submitCode",
        "title": "PtLPOJ: Submit Current File"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ptlpoj-explorer",
          "title": "PtLPOJ",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "ptlpoj-explorer": [
        {
          "id": "ptlpoj.problemsView",
          "name": "Problem Sets"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ptlpoj.submitCode",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus && editorLangId == python"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}