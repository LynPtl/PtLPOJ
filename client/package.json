{
  "name": "ptlpoj-client",
  "publisher": "ptlpoj",
  "displayName": "PtLPOJ Local Judge",
  "description": "Inner Team Python Online Judge Client",
  "version": "0.2.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/LynPtl/PtLPOJ.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ptlpoj.login",
        "title": "PtLPOJ: Login via OTP"
      },
      {
        "command": "ptlpoj.refreshProblems",
        "title": "PtLPOJ: Refresh Problems"
      },
      {
        "command": "ptlpoj.openProblem",
        "title": "PtLPOJ: Open Problem"
      },
      {
        "command": "ptlpoj.submitCode",
        "title": "PtLPOJ: Submit Current File"
      },
      {
        "command": "ptlpoj.runTest",
        "title": "PtLPOJ: Run Local Test"
      },
      {
        "command": "ptlpoj.openDashboard",
        "title": "PtLPOJ: Show Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "ptlpoj.setFilterSort",
        "title": "PtLPOJ: Filter & Sort Problems",
        "icon": "$(filter)"
      },
      {
        "command": "ptlpoj.searchProblems",
        "title": "PtLPOJ: Search Problems",
        "icon": "$(search)"
      },
      {
        "command": "ptlpoj.logout",
        "title": "PtLPOJ: Logout"
      },
      {
        "command": "ptlpoj.setConfig",
        "title": "PtLPOJ: Set Server URL",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ptlpoj.refreshProblems",
          "when": "view == ptlpoj.problemsView",
          "group": "navigation"
        },
        {
          "command": "ptlpoj.openDashboard",
          "when": "view == ptlpoj.problemsView",
          "group": "navigation"
        },
        {
          "command": "ptlpoj.setFilterSort",
          "when": "view == ptlpoj.problemsView",
          "group": "navigation"
        },
        {
          "command": "ptlpoj.searchProblems",
          "when": "view == ptlpoj.problemsView",
          "group": "navigation"
        },
        {
          "command": "ptlpoj.setConfig",
          "when": "view == ptlpoj.problemsView",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ptlpoj-explorer",
          "title": "PtLPOJ",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "ptlpoj-explorer": [
        {
          "id": "ptlpoj.problemsView",
          "name": "Problem Sets",
          "icon": "$(list-unordered)"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ptlpoj.submitCode",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus && editorLangId == python"
      }
    ],
    "configuration": {
      "title": "PtLPOJ",
      "properties": {
        "ptlpoj.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080/api",
          "description": "The base URL of the PtLPOJ server (e.g. http://192.168.1.100:8080/api)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "katex": "^0.16.33",
    "markdown-it": "^14.1.1",
    "markdown-it-katex": "^2.0.3"
  }
}